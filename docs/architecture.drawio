        <!-- Three mechanisms -->
        <mxCell id="mech_label" value="THREE RELIABILITY MECHANISMS" style="text;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#64748b;fontSize=9;fontStyle=1;fontFamily=Helvetica;spacingLeft=4;" vertex="1" parent="g_agent">
          <mxGeometry x="40" y="375" width="300" height="20" as="geometry" />
        </mxCell>
        <mxCell id="mech1" value="1. Pinned Todo List&#xa;Plan at system prompt position #2.&#xa;Re-injected EVERY API call.&#xa;Never buried in conversation history." style="rounded=1;arcSize=15;fillColor=#1a2332;strokeColor=#2a3a4a;fontColor=#e2e8f0;fontSize=10;fontFamily=Helvetica;strokeWidth=1.5;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="g_agent">
          <mxGeometry x="40" y="400" width="200" height="85" as="geometry" />
        </mxCell>
        <mxCell id="mech2" value="2. Re-injected Hints&#xa;Every tool_result carries [NEXT]&#xa;instruction steering agent to&#xa;the next logical action." style="rounded=1;arcSize=15;fillColor=#1a2332;strokeColor=#2a3a4a;fontColor=#e2e8f0;fontSize=10;fontFamily=Helvetica;strokeWidth=1.5;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="g_agent">
          <mxGeometry x="250" y="400" width="200" height="85" as="geometry" />
        </mxCell>
        <mxCell id="mech3" value="3. Exit Gate&#xa;If agent stops with incomplete&#xa;tasks: inject &quot;you have N tasks&#xa;left&quot; and force loop (3 retries)." style="rounded=1;arcSize=15;fillColor=#1a2332;strokeColor=#2a3a4a;fontColor=#e2e8f0;fontSize=10;fontFamily=Helvetica;strokeWidth=1.5;align=left;spacingLeft=10;spacingTop=6;" vertex="1" parent="g_agent">
