# ─── Backend (FastAPI Server) ─────────────────────────────
# Required: Anthropic API key for Claude agent
ANTHROPIC_API_KEY=sk-ant-your-key-here

# CORS: comma-separated origins allowed to call the API
CORS_ORIGINS=https://chicagointelligence.com,https://www.chicagointelligence.com,http://localhost:3000

# ─── Supply Chain Tool API Keys (Free tiers) ─────────────
# Alpha Vantage — commodity prices (get free key at alphavantage.co)
ALPHA_VANTAGE_API_KEY=demo

# FRED — economic indicators (get free key at fred.stlouisfed.org)
FRED_API_KEY=

# Census Bureau — US trade data (get free key at api.census.gov)
CENSUS_API_KEY=

# ─── Frontend (Next.js Dashboard) ────────────────────────
# These go in dashboard/.env.local (or dashboard/.env.production)

# Mapbox GL token for 3D map (get at mapbox.com)
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# API server URL (set to your Railway deployment URL)
# NEXT_PUBLIC_API_URL=https://api.chicagointelligence.com

# WebSocket URL (same as API but with wss://)
# NEXT_PUBLIC_WS_URL=wss://api.chicagointelligence.com
